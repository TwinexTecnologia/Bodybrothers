{
  "expo": {
    "name": "FitBody Pro",
    "slug": "fitbody-pro",
    "scheme": "fitbody-pro",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.twinex.fitbodypro",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsArbitraryLoadsInMedia": true
        }
      },
      "buildNumber": "5"
    },
    "android": {
      "package": "com.twinex.fitbodypro",
      "versionCode": 8,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "O aplicativo precisa acessar suas fotos para enviar imagens na anamnese e evolução.",
          "cameraPermission": "O aplicativo precisa acessar sua câmera para tirar fotos na anamnese e evolução."
        }
      ],
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3b82f6",
          "defaultChannel": "training_active",
          "sounds": [
            "./assets/sounds/training_active.wav",
            "./assets/sounds/training_paused.wav"
          ],
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4b43fac9-1a1e-44f2-af06-2713a3e3e1b0"
      }
    }
  }
}
